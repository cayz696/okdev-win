[Unit]
Description=okdev.win blog publish bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_LINUX_USER
WorkingDirectory=/home/YOUR_LINUX_USER/portfolio/bot
EnvironmentFile=/home/YOUR_LINUX_USER/portfolio/bot/.env
ExecStart=/home/YOUR_LINUX_USER/portfolio/bot/.venv/bin/python publish_bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
