# Telegram blog publish bot — copy to .env and fill in
TELEGRAM_BOT_TOKEN=
WORKER_URL=https://portfolio-contact-form.cayz696.workers.dev
PUBLISH_SECRET=
ALLOWED_USER_IDS=123456789
TELEGRAM_CHANNEL_ID=@your_channel

# OpenRouter AI (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
# ~$0.014/img — FLUX.2 Klein 4B (баланс ціна/якість)
# Альтернативи: google/gemini-3.1-flash-lite-image (дешевше), sourceful/riverflow-v2.5-fast (~$0.02)
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
SITE_DOMAIN=https://www.okdev.win
BOT_TIMEZONE=Europe/Kyiv
# Перевірка черги автопублікації (секунди). 120 = кожні 2 хв.
SCHEDULE_CHECK_SECONDS=120
